generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  passwordResets PasswordReset[]
  profiles       Profile[]
}

model Profile {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  niche       String
  platforms   String[]
  avatarColor String             @default("#6366f1")
  createdAt   DateTime           @default(now())
  content     ContentItem[]
  trends      TrendAlert[]
  giveaways   GiveawayCampaign[]

  @@index([userId])
}

model ContentItem {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  caption     String
  hashtags    String[]
  platform    String
  status      String    @default("draft")
  contentType String    @default("post")
  scheduledAt DateTime?
  publishedAt DateTime?
  mediaUrl    String?
  createdAt   DateTime  @default(now())
}

model TrendAlert {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  keyword     String
  trendScore  Float    @default(0)
  platform    String
  detectedAt  DateTime @default(now())
  actionTaken Boolean  @default(false)
}

model CardListing {
  id             String   @id @default(cuid())
  player         String
  set            String
  year           Int
  grade          Float?
  soldPrice      Float
  sourcePlatform String   @default("ebay")
  soldAt         DateTime
  sourceUrl      String
  createdAt      DateTime @default(now())
}

model GiveawayCampaign {
  id            String   @id @default(cuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title         String
  prize         String
  entryMechanic String
  postCopy      String
  hashtags      String[]
  status        String   @default("draft")
  createdAt     DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
